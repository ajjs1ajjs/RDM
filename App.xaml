<Application x:Class="RemoteManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:RemoteManager.Converters"
             xmlns:views="clr-namespace:RemoteManager.Views"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Theme.xaml"/>
                <ResourceDictionary Source="Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <c:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <c:InverseBoolConverter x:Key="InverseBool"/>
            <c:TypeToColorConverter x:Key="TypeToColor"/>
            <c:RadioBoolToConnectionTypeRdpConverter x:Key="RadioBoolToConnectionTypeRdp"/>
            <c:RadioBoolToConnectionTypeSshConverter x:Key="RadioBoolToConnectionTypeSsh"/>
            <c:TypeToRdpVisibilityConverter x:Key="TypeToRdpVisibility"/>
            <c:TypeToSshVisibilityConverter x:Key="TypeToSshVisibility"/>
            <c:StatusDotConverter x:Key="StatusDotConverter"/>
            <c:StatusTextConverter x:Key="StatusTextConverter"/>
            <c:TabMarginConverter x:Key="TabMarginConverter"/>
            <c:NullToVisibilityConverter x:Key="NullToCollapsed"/>
            <c:EnumToIntConverter x:Key="EnumToInt"/>
            <c:SshAuthTypeToVisibilityConverter x:Key="TypeToSshKeyVisibility"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
