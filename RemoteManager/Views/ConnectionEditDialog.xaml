<Window x:Class="RemoteManager.Views.ConnectionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RemoteManager.ViewModels"
        Title="{Binding WindowTitle}" Height="560" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>

            <!-- Type toggle -->
            <TextBlock Text="{Binding ValidationError}" Foreground="Red" FontWeight="SemiBold"
                       Margin="0,0,0,10" Visibility="{Binding ValidationError, Converter={StaticResource NullToCollapsed}}"
                       TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <RadioButton Content="RDP" GroupName="ConnType" Margin="0,0,15,0" FontSize="14" FontWeight="Bold"
                             IsChecked="{Binding SelectedType, Converter={StaticResource RadioBoolToConnectionTypeRdp}}"/>
                <RadioButton Content="SSH" GroupName="ConnType" FontSize="14" FontWeight="Bold"
                             IsChecked="{Binding SelectedType, Converter={StaticResource RadioBoolToConnectionTypeSsh}}"/>
            </StackPanel>

            <!-- Common fields -->
            <GroupBox Header="ℹ️ General" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Margin="0,3"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Host:" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Host}" Margin="0,3"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Port:" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Port}" Width="100" HorizontalAlignment="Left" Margin="0,3"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Username:" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding UserName}" Margin="0,3"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,5"/>
                    <Grid Grid.Row="4" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox Grid.Column="0" x:Name="PasswordBox" Margin="0,3"/>
                        <CheckBox Grid.Column="1" Content="Save" IsChecked="{Binding SavePassword}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Group:" VerticalAlignment="Center" Margin="0,5"/>
                    <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding Groups}"
                              SelectedValue="{Binding SelectedGroupId}"
                              SelectedValuePath="Id" DisplayMemberPath="Name" Margin="0,3"/>
                </Grid>
            </GroupBox>

            <!-- RDP Settings -->
            <GroupBox Header="🖥️ RDP Settings" Padding="10" Margin="0,0,0,10"
                      Visibility="{Binding SelectedType, Converter={StaticResource TypeToRdpVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Desktop width:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RdpWidth}" Margin="0,3,10,3"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Desktop height:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding RdpHeight}" Margin="0,3"/>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="Redirect clipboard"
                              IsChecked="{Binding RdpRedirectClipboard}" Margin="0,5"/>
                    <CheckBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Content="Redirect drives"
                              IsChecked="{Binding RdpRedirectDrives}" Margin="0,5"/>

                    <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="Redirect printers"
                              IsChecked="{Binding RdpRedirectPrinters}" Margin="0,5"/>
                    <CheckBox Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Content="CredSSP support"
                              IsChecked="{Binding RdpCredSsp}" Margin="0,5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Audio mode:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                              SelectedIndex="{Binding RdpAudioMode}" Margin="0,3">
                        <ComboBoxItem Content="Play locally"/>
                        <ComboBoxItem Content="Play on server"/>
                        <ComboBoxItem Content="No audio"/>
                    </ComboBox>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Gateway host:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding RdpGatewayHost}" Margin="0,3"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Gateway port:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding RdpGatewayPort}" Width="80" HorizontalAlignment="Left" Margin="0,3"/>
                </Grid>
            </GroupBox>

            <!-- SSH Settings -->
            <GroupBox Header="🔌 SSH Settings" Padding="10" Margin="0,0,0,10"
                      Visibility="{Binding SelectedType, Converter={StaticResource TypeToSshVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Auth type:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" SelectedIndex="{Binding SshAuthType, Converter={StaticResource EnumToInt}}" Margin="0,3">
                        <ComboBoxItem Content="Password"/>
                        <ComboBoxItem Content="Key"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Key file:" VerticalAlignment="Center"/>
                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SshKeyPath}" IsReadOnly="True" Margin="0,3"/>
                        <Button Grid.Column="1" Content="Browse" Padding="8,3" Margin="5,0,0,0"
                                Command="{Binding BrowseSshKeyCommand}"
                                Background="{StaticResource AccentBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand"/>
                    </Grid>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Keep alive (s):" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SshKeepAlive}" Width="80" HorizontalAlignment="Left" Margin="0,3"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Jump host:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SshJumpHost}" Margin="0,3"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Jump host port:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SshJumpHostPort}" Width="80" HorizontalAlignment="Left" Margin="0,3"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Jump host user:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SshJumpHostUsername}" Margin="0,3"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Jump host pass:" VerticalAlignment="Center"/>
                    <PasswordBox Grid.Row="6" Grid.Column="1" x:Name="SshJumpHostPasswordBox" Margin="0,3" MaxWidth="300" HorizontalAlignment="Left"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Key passphrase:" VerticalAlignment="Center"
                               Visibility="{Binding SshAuthType, Converter={StaticResource TypeToSshKeyVisibility}}"/>
                    <PasswordBox Grid.Row="7" Grid.Column="1" x:Name="SshKeyPassphraseBox" Margin="0,3" MaxWidth="300" HorizontalAlignment="Left"
                                 Visibility="{Binding SshAuthType, Converter={StaticResource TypeToSshKeyVisibility}}"/>
                </Grid>
            </GroupBox>

            <!-- Description -->
            <GroupBox Header="📝 Description" Padding="10" Margin="0,0,0,15">
                <TextBox Text="{Binding Description}" Height="60" AcceptsReturn="True"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </GroupBox>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Cancel" Padding="20,10" Margin="0,0,12,0" Click="OnCancel"
                        Background="Transparent" BorderThickness="1"
                        BorderBrush="{StaticResource CtrlBorderBrush}"/>
                <Button Content="💾 Save Connection" Padding="25,10" Click="OnSave"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        BorderThickness="0" FontWeight="Bold"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
