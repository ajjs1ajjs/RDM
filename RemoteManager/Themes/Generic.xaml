<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:RemoteManager.Controls">

    <Style TargetType="{x:Type local:SshTerminalControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SshTerminalControl}">
                    <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource CtrlBorderBrush}" BorderThickness="1" CornerRadius="2">
                        <ScrollViewer x:Name="PART_ScrollViewer"
                                      Background="#000000"
                                      Padding="10"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Focusable="False">
                            <TextBlock x:Name="PART_OutputText"
                                       Background="#000000"
                                       Foreground="#D4D4D4"
                                       FontFamily="Consolas, 'Courier New'"
                                       FontSize="13"
                                       TextWrapping="NoWrap"
                                       Focusable="False"/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
