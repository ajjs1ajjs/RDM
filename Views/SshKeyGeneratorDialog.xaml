<Window x:Class="RemoteManager.Views.SshKeyGeneratorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:RemoteManager.Helpers"
        Title="{x:Static helpers:L.KeyGen_Title}" Height="450" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}">
    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="{x:Static helpers:L.KeyGen_GenerateKeys}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,0,0,10" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}"/>

            <TextBlock Text="{x:Static helpers:L.KeyGen_KeyType}" Margin="0,5"/>
            <ComboBox SelectedIndex="{Binding SelectedKeyTypeIndex}" Margin="0,0,0,15">
                <ComboBoxItem Content="{x:Static helpers:L.KeyGen_RSA2048}"/>
                <ComboBoxItem Content="{x:Static helpers:L.KeyGen_RSA4096}"/>
                <ComboBoxItem Content="{x:Static helpers:L.KeyGen_ED25519}"/>
                <ComboBoxItem Content="{x:Static helpers:L.KeyGen_ECDSA256}"/>
                <ComboBoxItem Content="{x:Static helpers:L.KeyGen_ECDSA384}"/>
                <ComboBoxItem Content="{x:Static helpers:L.KeyGen_ECDSA521}"/>
            </ComboBox>

            <TextBlock Text="{x:Static helpers:L.KeyGen_Passphrase}" Margin="0,5"/>
            <TextBox Text="{Binding Passphrase}" Margin="0,0,0,15"/>

            <TextBlock Text="{x:Static helpers:L.KeyGen_SaveToDirectory}" Margin="0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SaveDirectory}" IsReadOnly="True" Margin="0,0,5,0"/>
                <Button Grid.Column="1" Content="{x:Static helpers:L.KeyGen_BrowseTitle}" Command="{Binding BrowseDirectoryCommand}" Padding="8,2"
                        Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>

            <TextBlock Text="{x:Static helpers:L.KeyGen_KeyName}" Margin="0,5"/>
            <TextBox Text="{Binding KeyName}" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{x:Static helpers:L.KeyGen_Cancel}" Padding="15,8" Margin="0,0,10,0" Click="OnCancel"
                        Background="Transparent" BorderThickness="1" BorderBrush="{StaticResource CtrlBorderBrush}"/>
                <Button Content="{x:Static helpers:L.KeyGen_GenerateSave}" Padding="15,8" Click="OnSave"
                        Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
