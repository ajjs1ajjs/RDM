<Window x:Class="RemoteManager.Views.ConnectionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RemoteManager.ViewModels"
        xmlns:helpers="clr-namespace:RemoteManager.Helpers"
        Title="{Binding WindowTitle}" Height="560" Width="550"
        Icon="pack://application:,,,/RemoteManager;component/Resources/Icons/app_icon.png"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>

            <!-- Type toggle -->
            <TextBlock Text="{Binding ValidationError}" Foreground="Red" FontWeight="SemiBold"
                       Margin="0,0,0,10" Visibility="{Binding ValidationError, Converter={StaticResource NullToCollapsed}}"
                       TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <RadioButton Content="{x:Static helpers:L.ConnEdit_RDP}" GroupName="ConnType" Margin="0,0,15,0" FontSize="14" FontWeight="Bold"
                             IsChecked="{Binding SelectedType, Converter={StaticResource RadioBoolToConnectionTypeRdp}}"/>
                <RadioButton Content="{x:Static helpers:L.ConnEdit_SSH}" GroupName="ConnType" FontSize="14" FontWeight="Bold" Margin="0,0,15,0"
                             IsChecked="{Binding SelectedType, Converter={StaticResource RadioBoolToConnectionTypeSsh}}"/>

            </StackPanel>

            <!-- Common fields -->
            <GroupBox Header="{x:Static helpers:L.ConnEdit_General}" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_Name}" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Margin="0,3"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_Host}" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Host}" Margin="0,3"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_Port}" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Port}" Width="100" HorizontalAlignment="Left" Margin="0,3"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_Username}" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding UserName}" Margin="0,3"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_Password}" VerticalAlignment="Center" Margin="0,5"/>
                    <Grid Grid.Row="4" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox Grid.Column="0" x:Name="PasswordBox" Margin="0,3"/>
                        <Button Grid.Column="1" Command="{Binding GeneratePasswordCommand}" Content="{x:Static helpers:L.ConnEdit_Generate}" Margin="8,0,0,0" Padding="5,2" ToolTip="{x:Static helpers:L.ConnEdit_GenerateTooltip}"/>
                        <CheckBox Grid.Column="2" Content="{x:Static helpers:L.ConnEdit_Save}" IsChecked="{Binding SavePassword}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_Group}" VerticalAlignment="Center" Margin="0,5"/>
                    <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding Groups}"
                              SelectedValue="{Binding SelectedGroupId}"
                              SelectedValuePath="Id" DisplayMemberPath="Name" Margin="0,3"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_MacAddress}" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding MacAddress}" ToolTip="{x:Static helpers:L.ConnEdit_MacAddressTooltip}" Margin="0,3"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_Tags}" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding TagsText}" ToolTip="{x:Static helpers:L.ConnEdit_TagsTooltip}" Margin="0,3"/>
                </Grid>
            </GroupBox>

            <!-- RDP Settings -->
            <GroupBox Header="{x:Static helpers:L.ConnEdit_RdpSettings}" Padding="10" Margin="0,0,0,10"
                      Visibility="{Binding SelectedType, Converter={StaticResource TypeToRdpVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_RdpWidth}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RdpWidth}" Margin="0,3,10,3"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Static helpers:L.ConnEdit_RdpHeight}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding RdpHeight}" Margin="0,3"/>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="{x:Static helpers:L.ConnEdit_RdpRedirectClipboard}"
                              IsChecked="{Binding RdpRedirectClipboard}" Margin="0,5"/>
                    <CheckBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Content="{x:Static helpers:L.ConnEdit_RdpRedirectDrives}"
                              IsChecked="{Binding RdpRedirectDrives}" Margin="0,5"/>

                    <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="{x:Static helpers:L.ConnEdit_RdpRedirectPrinters}"
                              IsChecked="{Binding RdpRedirectPrinters}" Margin="0,5"/>
                    <CheckBox Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Content="{x:Static helpers:L.ConnEdit_RdpUseMultimon}"
                              IsChecked="{Binding RdpUseMultimon}" Margin="0,5"/>

                    <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="{x:Static helpers:L.ConnEdit_RdpCredSsp}"
                              IsChecked="{Binding RdpCredSsp}" Margin="0,5"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_RdpAudioMode}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                              SelectedIndex="{Binding RdpAudioMode}" Margin="0,3">
                        <ComboBoxItem Content="{x:Static helpers:L.ConnEdit_RdpPlayLocally}"/>
                        <ComboBoxItem Content="{x:Static helpers:L.ConnEdit_RdpPlayOnServer}"/>
                        <ComboBoxItem Content="{x:Static helpers:L.ConnEdit_RdpNoAudio}"/>
                    </ComboBox>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_RdpGatewayHost}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding RdpGatewayHost}" Margin="0,3"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_RdpGatewayPort}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding RdpGatewayPort}" Width="80" HorizontalAlignment="Left" Margin="0,3"/>
                </Grid>
            </GroupBox>

            <!-- SSH Settings -->
            <GroupBox Header="{x:Static helpers:L.ConnEdit_SshSettings}" Padding="10" Margin="0,0,0,10"
                      Visibility="{Binding SelectedType, Converter={StaticResource TypeToSshVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshAuthType}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" SelectedIndex="{Binding SshAuthType, Converter={StaticResource EnumToInt}}" Margin="0,3">
                        <ComboBoxItem Content="{x:Static helpers:L.ConnEdit_SshPassword}"/>
                        <ComboBoxItem Content="{x:Static helpers:L.ConnEdit_SshKey}"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshKeyFile}" VerticalAlignment="Center"/>
                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SshKeyPath}" IsReadOnly="True" Margin="0,3"/>
                        <Button Grid.Column="1" Content="{x:Static helpers:L.ConnEdit_Browse}" Padding="8,3" Margin="5,0,0,0"
                                Command="{Binding BrowseSshKeyCommand}"
                                Background="{StaticResource AccentBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand"/>
                        <Button Grid.Column="2" Content="{x:Static helpers:L.ConnEdit_GenerateKey}" Padding="8,3" Margin="5,0,0,0"
                                Click="OnGenerateSshKey"
                                Background="{StaticResource AccentBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand"/>
                    </Grid>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshKeepAlive}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SshKeepAlive}" Width="80" HorizontalAlignment="Left" Margin="0,3"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshJumpHost}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SshJumpHost}" Margin="0,3"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshJumpHostPort}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SshJumpHostPort}" Width="80" HorizontalAlignment="Left" Margin="0,3"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshJumpHostUser}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SshJumpHostUsername}" Margin="0,3"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshJumpHostPass}" VerticalAlignment="Center"/>
                    <PasswordBox Grid.Row="6" Grid.Column="1" x:Name="SshJumpHostPasswordBox" Margin="0,3" MaxWidth="300" HorizontalAlignment="Left"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshKeyPassphrase}" VerticalAlignment="Center"
                               Visibility="{Binding SshAuthType, Converter={StaticResource TypeToSshKeyVisibility}}"/>
                    <PasswordBox Grid.Row="7" Grid.Column="1" x:Name="SshKeyPassphraseBox" Margin="0,3" MaxWidth="300" HorizontalAlignment="Left"
                                 Visibility="{Binding SshAuthType, Converter={StaticResource TypeToSshKeyVisibility}}"/>

                    <!-- Port Forwarding Settings -->
                    <Expander Grid.Row="8" Grid.ColumnSpan="2" Header="{x:Static helpers:L.ConnEdit_SshPortForwarding}" Margin="0,10,0,0">
                        <Grid Margin="10,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <CheckBox Grid.Row="0" Grid.ColumnSpan="2" Content="{x:Static helpers:L.ConnEdit_SshPortForwardingEnable}"
                                      IsChecked="{Binding SshPortForwardingEnabled}" Margin="0,5" FontWeight="Bold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshPortForwardingLocalPort}" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SshPortForwardingLocalPort}" Width="80" HorizontalAlignment="Left" Margin="0,3"
                                     IsEnabled="{Binding SshPortForwardingEnabled}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshPortForwardingRemoteHost}" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SshPortForwardingRemoteHost}" Margin="0,3"
                                     IsEnabled="{Binding SshPortForwardingEnabled}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static helpers:L.ConnEdit_SshPortForwardingRemotePort}" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SshPortForwardingRemotePort}" Width="80" HorizontalAlignment="Left" Margin="0,3"
                                     IsEnabled="{Binding SshPortForwardingEnabled}"/>
                        </Grid>
                    </Expander>
                </Grid>
            </GroupBox>

            <!-- Description -->
            <GroupBox Header="{x:Static helpers:L.ConnEdit_Description}" Padding="10" Margin="0,0,0,15">
                <TextBox Text="{Binding Description}" Height="60" AcceptsReturn="True"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </GroupBox>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="{x:Static helpers:L.ConnEdit_Cancel}" Padding="20,10" Margin="0,0,12,0" Click="OnCancel"
                        Background="Transparent" BorderThickness="1"
                        BorderBrush="{StaticResource CtrlBorderBrush}"/>
                <Button Content="{x:Static helpers:L.ConnEdit_SaveConnection}" Padding="25,10" Click="OnSave"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        BorderThickness="0" FontWeight="Bold"/>
            </StackPanel>


        </StackPanel>
    </ScrollViewer>
</Window>
