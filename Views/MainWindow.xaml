<Window x:Class="RemoteManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
        xmlns:vm="clr-namespace:RemoteManager.ViewModels"
        xmlns:views="clr-namespace:RemoteManager.Views"
        Title="RemoteManager" Height="800" Width="1200"
        Icon="pack://application:,,,/RemoteManager;component/Resources/Icons/app_icon.png"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Foreground="{StaticResource FgBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:RdpSessionViewModel}">
            <views:RdpSessionView DataContext="{Binding}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SshSessionViewModel}">
            <views:SshSessionView DataContext="{Binding}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SftpSessionViewModel}">
            <views:SftpSessionView DataContext="{Binding}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WebSessionViewModel}">
            <views:WebSessionView DataContext="{Binding}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsTabViewModel}">
            <views:SettingsView DataContext="{Binding Settings}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </DataTemplate>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Modifiers="Control" Key="W" Command="{Binding CloseCurrentTabCommand}"/>
        <KeyBinding Modifiers="Control" Key="T" Command="{Binding NewSshCommand}"/>
        <KeyBinding Modifiers="Control" Key="R" Command="{Binding NewRdpCommand}"/>
    </Window.InputBindings>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="200" MaxWidth="380"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Full-width background -->
            <Grid Grid.ColumnSpan="3" IsHitTestVisible="False">
                <Image Source="pack://application:,,,/RemoteManager;component/Resources/Icons/space_bg.png" Stretch="UniformToFill" Opacity="0.12"/>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF080C14" Offset="0"/>
                            <GradientStop Color="#FF0E1430" Offset="0.4"/>
                            <GradientStop Color="#FF080C14" Offset="0.7"/>
                            <GradientStop Color="#FF0A0F20" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Ellipse Fill="#818CF8" Opacity="0.08" Width="900" Height="900" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-300,-200,0"/>
                <Ellipse Fill="#22D3EE" Opacity="0.06" Width="700" Height="700" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-200,0,0,-200"/>
                <Ellipse Fill="#A855F7" Opacity="0.04" Width="500" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,100,0,0"/>
            </Grid>

            <!-- Sidebar -->
            <Border Grid.Column="0" Grid.ZIndex="10"
                    Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}"
                    BorderBrush="#15FFFFFF" BorderThickness="0,0,1,0">
                <Border.Background>
                    <SolidColorBrush Color="#0C1122" Opacity="0.88"/>
                </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="Transparent" Padding="18,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="pack://application:,,,/RemoteManager;component/Resources/Icons/app_icon.png" Width="36" Height="36" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="RemoteManager" FontSize="20" FontWeight="Bold" Foreground="{StaticResource FgBrush}"/>
                            <TextBlock Text="CONNECTION CENTER" FontSize="9" FontWeight="Bold" Foreground="{StaticResource FgDimBrush}" Margin="0,2,0,0" Opacity="0.6"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Search -->
                <Border Grid.Row="1" Padding="12,8">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Search connections..." FontSize="12"
                             Height="34" VerticalContentAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="16"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Border>

                <!-- Quick actions -->
                <Border Grid.Row="2" Padding="12,6,12,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <WrapPanel Grid.Column="0">
                            <!-- Group Button -->
                            <Button Command="{Binding AddGroupCommand}" Height="28" Margin="0,0,4,4" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="14" Padding="8,3" x:Name="Bd">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                                    <GradientStop Color="#60A5FA" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#3B82F6" Opacity="0.3" BlurRadius="8" ShadowDepth="0"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="White" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                <TextBlock Text="Group" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- RDP Button -->
                            <Button Command="{Binding AddConnectionCommand}" CommandParameter="RDP" Height="28" Margin="0,0,4,4" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="14" Padding="8,3" x:Name="Bd">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#22D3EE" Offset="0"/>
                                                    <GradientStop Color="#38BDF8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#22D3EE" Opacity="0.25" BlurRadius="8" ShadowDepth="0"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="White" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                <TextBlock Text="RDP" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- SSH Button -->
                            <Button Command="{Binding AddConnectionCommand}" CommandParameter="SSH" Height="28" Margin="0,0,4,4" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="14" Padding="8,3" x:Name="Bd">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#A855F7" Offset="0"/>
                                                    <GradientStop Color="#C084FC" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#A855F7" Opacity="0.25" BlurRadius="8" ShadowDepth="0"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE9A9;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="White" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                <TextBlock Text="SSH" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>


                        </WrapPanel>

                        <!-- Settings Button -->
                        <Button Grid.Column="1" Command="{Binding ShowSettingsCommand}" Width="30" Height="30" Margin="4,0,0,0"
                                Background="Transparent" Foreground="{StaticResource FgBrush}"
                                BorderThickness="0" Cursor="Hand" ToolTip="Settings">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" CornerRadius="15" x:Name="Bd">
                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
                <!-- Tree -->
                <TreeView Grid.Row="3" ItemsSource="{Binding Groups}" Padding="4,0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          Background="Transparent" BorderThickness="0">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:GroupViewModel}" ItemsSource="{Binding Children}">
                            <Border Padding="4,3" Background="Transparent" HorizontalAlignment="Stretch"
                                    Tag="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Rename Group"
                                                  Command="{Binding PlacementTarget.Tag.DataContext.RenameGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Delete Group"
                                                  Command="{Binding PlacementTarget.Tag.DataContext.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Add RDP Connection" CommandParameter="RDP"
                                                  Command="{Binding PlacementTarget.Tag.DataContext.AddConnectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Add SSH Connection" CommandParameter="SSH"
                                                  Command="{Binding PlacementTarget.Tag.DataContext.AddConnectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE9A9;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type vm:ConnectionItemViewModel}">
                            <Border Padding="6,4,4,4" Margin="0,1" Background="Transparent" HorizontalAlignment="Stretch"
                                    Tag="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick"
                                                  Command="{Binding Tag.DataContext.OpenConnectionCommand, RelativeSource={RelativeSource AncestorType={x:Type Border}}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Connect"
                                                  Command="{Binding PlacementTarget.Tag.DataContext.OpenConnectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Open SFTP Browser"
                                                  Command="{Binding PlacementTarget.Tag.DataContext.OpenSftpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Wake on LAN"
                                                  Command="{Binding PlacementTarget.Tag.DataContext.WakeUpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE7E3;" FontFamily="Segoe MDL2 Assets"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Edit..."
                                                  Command="{Binding PlacementTarget.Tag.DataContext.EditConnectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Duplicate"
                                                  Command="{Binding PlacementTarget.Tag.DataContext.DuplicateConnectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Delete"
                                                  Command="{Binding PlacementTarget.Tag.DataContext.DeleteConnectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid Margin="0,0,6,0" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0"
                                             x:Name="StatusDot" Fill="#555555" ToolTip="Status: Unknown"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TypeIcon}" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Grid Grid.Column="2" VerticalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Host}" FontSize="10" Foreground="{StaticResource FgDimBrush}" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Grid>
                            </Border>
                            <HierarchicalDataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter TargetName="StatusDot" Property="Fill" Value="#10B981"/>
                                    <Setter TargetName="StatusDot" Property="ToolTip" Value="Connected (Active Session)"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsConnected}" Value="False"/>
                                        <Condition Binding="{Binding PingStatus}" Value="Online"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="StatusDot" Property="Fill" Value="#34D399"/>
                                    <Setter TargetName="StatusDot" Property="ToolTip" Value="{Binding PingLatency, StringFormat='Online ({0}ms)'}"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsConnected}" Value="False"/>
                                        <Condition Binding="{Binding PingStatus}" Value="Offline"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="StatusDot" Property="Fill" Value="#EF4444"/>
                                    <Setter TargetName="StatusDot" Property="ToolTip" Value="Offline"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsConnected}" Value="False"/>
                                        <Condition Binding="{Binding PingStatus}" Value="Checking"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="StatusDot" Property="Fill" Value="#F59E0B"/>
                                    <Setter TargetName="StatusDot" Property="ToolTip" Value="Checking status..."/>
                                </MultiDataTrigger>
                            </HierarchicalDataTemplate.Triggers>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4"
                      Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}"
                      Background="{StaticResource CtrlBorderBrush}"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- Main Content -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tabs -->
            <Border Grid.Row="0" Grid.ZIndex="5"
                    BorderBrush="#15FFFFFF"
                    BorderThickness="0,0,0,1">
                <Border.Background>
                    <SolidColorBrush Color="#0C1122" Opacity="0.85"/>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="☰" FontSize="14" Padding="12,6"
                            Background="Transparent" Foreground="{StaticResource FgBrush}"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip="Toggle Sidebar&#10;&#10;Shortcuts:&#10;F5: Refresh&#10;Ctrl+W: Close tab&#10;Ctrl+T: New SSH&#10;Ctrl+R: New RDP"/>

                    <ListBox Grid.Column="1" ItemsSource="{Binding OpenTabs}"
                             SelectedItem="{Binding SelectedTab}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource FgDimBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                <Setter Property="BorderBrush" Value="{StaticResource CtrlBorderBrush}"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="12,8">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgBrush}"/>
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,2"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBgBrush}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Header}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                                    <Button Content="✕" FontSize="10" Padding="4,2"
                                            Background="Transparent" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource TransparentButtonStyle}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Persisted Tab Content -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding OpenTabs}"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                        <Setter Property="Visibility" Value="{Binding IsSelected, Converter={StaticResource BoolToVis}}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <!-- Content will be rendered directly via DataTemplates defined in Window.Resources -->
            </ItemsControl>

            <!-- Dashboard (Visible when no tabs are open) -->
            <Grid Grid.Row="1" Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVis}}" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Recent Sessions Section -->
                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="Recent Sessions" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    <!-- List of connection cards -->
                    <ItemsControl ItemsSource="{Binding RecentConnections}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ConnectionItemViewModel}">
                                <!-- Card Button -->
                                <Button Command="{Binding DataContext.OpenConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Width="180" Height="70" Margin="0,0,15,0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                                                            <Border CornerRadius="10" Padding="12,10" x:Name="Bd"
                                                    BorderBrush="#20FFFFFF" BorderThickness="1">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#111B30" Opacity="0.6"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#818CF8" Opacity="0.08" BlurRadius="20" ShadowDepth="0"/>
                                                </Border.Effect>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <DockPanel Grid.Row="0">
                                                        <Ellipse x:Name="RecentStatusDot" Width="8" Height="8" Fill="#555555" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="4,0,0,0" ToolTip="Status: Unknown"/>
                                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                    </DockPanel>
                                                    <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                        <!-- Connection Type Indicator (cyan for RDP, indigo for SSH) -->
                                                        <Border CornerRadius="3" Padding="4,2" Margin="0,0,6,0" x:Name="TypeBadge">
                                                            <TextBlock Text="{Binding Type}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Host}" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="110"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#801E293B"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#406366F1"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding Type}" Value="RDP">
                                                    <Setter TargetName="TypeBadge" Property="Background" Value="#300EA5E9"/>
                                                    <Setter TargetName="TypeBadge" Property="BorderBrush" Value="#600EA5E9"/>
                                                    <Setter TargetName="TypeBadge" Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="SSH">
                                                    <Setter TargetName="TypeBadge" Property="Background" Value="#306366F1"/>
                                                    <Setter TargetName="TypeBadge" Property="BorderBrush" Value="#606366F1"/>
                                                    <Setter TargetName="TypeBadge" Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter TargetName="RecentStatusDot" Property="Fill" Value="#10B981"/>
                                                    <Setter TargetName="RecentStatusDot" Property="ToolTip" Value="Connected (Active Session)"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsConnected}" Value="False"/>
                                                        <Condition Binding="{Binding PingStatus}" Value="Online"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter TargetName="RecentStatusDot" Property="Fill" Value="#34D399"/>
                                                    <Setter TargetName="RecentStatusDot" Property="ToolTip" Value="{Binding PingLatency, StringFormat='Online ({0}ms)'}"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsConnected}" Value="False"/>
                                                        <Condition Binding="{Binding PingStatus}" Value="Offline"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter TargetName="RecentStatusDot" Property="Fill" Value="#EF4444"/>
                                                    <Setter TargetName="RecentStatusDot" Property="ToolTip" Value="Offline"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsConnected}" Value="False"/>
                                                        <Condition Binding="{Binding PingStatus}" Value="Checking"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter TargetName="RecentStatusDot" Property="Fill" Value="#F59E0B"/>
                                                    <Setter TargetName="RecentStatusDot" Property="ToolTip" Value="Checking status..."/>
                                                </MultiDataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Status Dashboard Central Card -->
                <Grid Grid.Row="1">
                    <!-- Dashboard Card Container -->
                    <Border Width="400" Height="290" HorizontalAlignment="Center" VerticalAlignment="Center"
                            CornerRadius="16" BorderThickness="1" BorderBrush="#30FFFFFF" Padding="28">
                        <Border.Background>
                            <SolidColorBrush Color="#0C1122" Opacity="0.7"/>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#818CF8" Opacity="0.15" BlurRadius="50" ShadowDepth="0"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Card Header -->
                            <TextBlock Grid.Row="0" Text="Status Dashboard" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                            <!-- Gauge Widgets Layout -->
                            <Grid Grid.Row="1" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>

                                <!-- Gauge 1: Active -->
                                <Grid Grid.Column="0" HorizontalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="80"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Width="60" Height="60" VerticalAlignment="Center">
                                        <!-- Gauge Track -->
                                        <Path Data="M 10 50 A 20 20 0 1 1 50 50" Stroke="#20FFFFFF" StrokeThickness="5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" Fill="Transparent"/>
                                        <!-- Needle -->
                                        <Line X1="30" Y1="30" X2="30" Y2="12" Stroke="#3B82F6" StrokeThickness="3" StrokeEndLineCap="Round">
                                            <Line.RenderTransform>
                                                <RotateTransform Angle="{Binding ActiveSessionsAngle}" CenterX="30" CenterY="30"/>
                                            </Line.RenderTransform>
                                        </Line>
                                        <Ellipse Width="8" Height="8" Fill="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,-8"/>
                                    </Grid>
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,5,0,0">
                                        <TextBlock Text="Active:" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ActiveSessionsCount}" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Gauge 2: Pending -->
                                <Grid Grid.Column="1" HorizontalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="80"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Width="60" Height="60" VerticalAlignment="Center">
                                        <!-- Gauge Track -->
                                        <Path Data="M 10 50 A 20 20 0 1 1 50 50" Stroke="#20FFFFFF" StrokeThickness="5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" Fill="Transparent"/>
                                        <!-- Needle -->
                                        <Line X1="30" Y1="30" X2="30" Y2="12" Stroke="#06B6D4" StrokeThickness="3" StrokeEndLineCap="Round">
                                            <Line.RenderTransform>
                                                <RotateTransform Angle="{Binding PendingSessionsAngle}" CenterX="30" CenterY="30"/>
                                            </Line.RenderTransform>
                                        </Line>
                                        <Ellipse Width="8" Height="8" Fill="#06B6D4" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,-8"/>
                                    </Grid>
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,5,0,0">
                                        <TextBlock Text="Pending:" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding PendingSessionsCount}" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Gauge 3: Latency -->
                                <Grid Grid.Column="2" HorizontalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="80"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Width="60" Height="60" VerticalAlignment="Center">
                                        <!-- Gauge Track -->
                                        <Path Data="M 10 50 A 20 20 0 1 1 50 50" Stroke="#20FFFFFF" StrokeThickness="5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" Fill="Transparent"/>
                                        <!-- Needle -->
                                        <Line X1="30" Y1="30" X2="30" Y2="12" Stroke="#6366F1" StrokeThickness="3" StrokeEndLineCap="Round">
                                            <Line.RenderTransform>
                                                <RotateTransform Angle="{Binding LatencyAngle}" CenterX="30" CenterY="30"/>
                                            </Line.RenderTransform>
                                        </Line>
                                        <Ellipse Width="8" Height="8" Fill="#6366F1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,-8"/>
                                    </Grid>
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,5,0,0">
                                        <TextBlock Text="Latency:" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Latency, StringFormat={}{0}ms}" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <!-- Add connection button -->
                            <Button Grid.Row="2" Command="{Binding AddConnectionCommand}" CommandParameter="RDP"
                                    Height="40" Cursor="Hand" Margin="0,20,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="20" BorderThickness="1" BorderBrush="#30FFFFFF" x:Name="BtnBd">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#818CF8" Offset="0.5"/>
                                    <GradientStop Color="#6366F1" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#818CF8" Opacity="0.4" BlurRadius="20" ShadowDepth="0"/>
                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="Add New Connection" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                                <TextBlock Text=" +" FontSize="14" FontWeight="Bold" Foreground="White" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBd" Property="Opacity" Value="0.9"/>
                                                <Setter TargetName="BtnBd" Property="BorderBrush" Value="#50FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="BtnBd" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Star/Sparkle deco at bottom right -->
                    <Path Data="M 20 0 L 23 15 L 38 18 L 23 21 L 20 36 L 17 21 L 2 18 L 17 15 Z"
                          Fill="#506366F1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                          Width="30" Height="30" Margin="0,0,20,20"/>
                </Grid>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2" Grid.ZIndex="5"
                    BorderBrush="#15FFFFFF"
                    BorderThickness="0,1,0,0" Padding="14,4">
                <Border.Background>
                    <SolidColorBrush Color="#0C1122" Opacity="0.8"/>
                </Border.Background>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding OpenTabs.Count, StringFormat='Tabs: {0}'}" FontSize="11"
                               Foreground="{StaticResource FgDimBrush}"/>
                    <TextBlock Text="{Binding Groups.Count, StringFormat='Groups: {0}'}" FontSize="11"
                               Foreground="{StaticResource FgDimBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

</Window>
