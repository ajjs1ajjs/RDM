<UserControl x:Class="RemoteManager.Views.SshSessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RemoteManager.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SSH Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource CtrlBorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="⛔ Disconnect" Margin="2,0" FontSize="11"
                        Command="{Binding DisconnectCommand}"
                        IsEnabled="{Binding IsConnected}"
                        Padding="8,4" Background="{StaticResource RedBrush}" Foreground="White"/>
                <Button Content="↻ Reconnect" Margin="8,0,2,0" FontSize="11"
                        Command="{Binding ReconnectCommand}"
                        IsEnabled="{Binding IsConnecting, Converter={StaticResource InverseBool}}"
                        Padding="8,4" Background="{StaticResource AccentBrush}" Foreground="White"/>
                <Button Content="🗑 Clear" Margin="8,0,2,0" FontSize="11"
                        Command="{Binding ClearCommand}"
                        Padding="8,4" Background="Transparent" Foreground="{StaticResource FgBrush}" BorderThickness="0"
                        ToolTip="Clear terminal (Ctrl+L)"/>

                <Menu Background="Transparent" Margin="8,0,2,0" VerticalAlignment="Center">
                    <MenuItem Header="📝 Snippets" ItemsSource="{Binding Snippets}" FontSize="11" Padding="8,4"
                              Background="Transparent" Foreground="{StaticResource FgBrush}">
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="Header" Value="{Binding Name}" />
                                <Setter Property="Command" Value="{Binding DataContext.ExecuteSnippetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <Setter Property="CommandParameter" Value="{Binding}" />
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                </Menu>

                <Separator Width="1" Background="{StaticResource CtrlBorderBrush}" Margin="8,4"/>
                <TextBlock Text="Ctrl+Shift+C/V: Copy/Paste" VerticalAlignment="Center" Margin="4,0"
                           FontSize="10" Foreground="{StaticResource FgDimBrush}" Opacity="0.5"/>
                <Separator Width="1" Background="{StaticResource CtrlBorderBrush}" Margin="8,4"/>
                <TextBlock Text="{Binding SessionInfo}" VerticalAlignment="Center" Margin="10,0,4,0"
                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}"/>
                <TextBlock Text="·" VerticalAlignment="Center" Margin="4,0" FontSize="11" Foreground="{StaticResource FgBrush}"/>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="4,0"
                           FontSize="11" Foreground="{StaticResource FgBrush}" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <controls:SshWebViewTerminalControl Grid.Row="1" x:Name="TerminalControl"/>
    </Grid>
</UserControl>
