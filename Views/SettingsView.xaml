<UserControl x:Class="RemoteManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:RemoteManager.Helpers">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
        <StackPanel MaxWidth="600">
            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Database Location -->
            <GroupBox Header="🗄️ Database" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Database path:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding CurrentDbPath, Mode=OneWay}"
                                 IsReadOnly="True" Padding="8,6"/>
                        <Button Grid.Column="1" Content="Browse..." Padding="12,6" Margin="8,0,0,0"
                                Command="{Binding ChangeDatabasePathCommand}"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                    <TextBlock Text="You can store the database in OneDrive or any custom location" 
                               FontSize="11" Opacity="0.6" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Backup & Sync -->
            <GroupBox Header="📥 Backup &amp; Sync (Резервне копіювання)" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Стандартний імпорт/експорт конфігурації (без паролів):" 
                               FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="📥 Import JSON/XML..." Padding="14,6" Margin="0,0,10,0"
                                Command="{Binding ImportConnectionsCommand}"
                                Background="Transparent" Foreground="{StaticResource AccentBrush}" 
                                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Cursor="Hand"
                                FontSize="11" FontWeight="SemiBold"/>
                        <Button Content="📤 Export JSON..." Padding="14,6"
                                Command="{Binding ExportConnectionsCommand}"
                                Background="Transparent" Foreground="{StaticResource AccentBrush}" 
                                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Cursor="Hand"
                                FontSize="11" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Border BorderBrush="{StaticResource CtrlBorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,15"/>

                    <TextBlock Text="🔒 Захищений бекап з паролями (Шифрування AES-256):" 
                               FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                    <TextBlock Text="Дозволяє зберегти підключення разом із паролями в один файл для перенесення на інший ПК або після перевстановлення Windows. Файл захищається вашим паролем." 
                               FontSize="10" Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="🔒 Import Secure Backup..." Padding="14,8" Margin="0,0,10,0"
                                Command="{Binding ImportEncryptedBackupCommand}"
                                Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                FontSize="11" FontWeight="Bold"/>
                        <Button Content="🔒 Export Secure Backup..." Padding="14,8"
                                Command="{Binding ExportEncryptedBackupCommand}"
                                Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Auto Backup Folder -->
            <GroupBox Header="🔄 Auto Backup Folder (Автоматичний бекап)" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Шлях для автоматичного збереження копій (OneDrive, Dropbox тощо):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding BackupFolderPath, Mode=OneWay}"
                                 IsReadOnly="True" Padding="8,6"/>
                        <Button Grid.Column="1" Content="Browse..." Padding="12,6" Margin="8,0,0,0"
                                Command="{Binding ChangeBackupFolderCommand}"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                    <TextBlock Text="Примітка: При налаштуванні цієї папки база даних, налаштування та паролі будуть автоматично копіюватися туди після кожної зміни. Паролі шифруються локальним ключем Windows DPAPI (відновлення паролів можливе на цьому ж ПК під цим же користувачем)." 
                               FontSize="11" Opacity="0.6" Margin="0,5,0,0" TextWrapping="Wrap"/>
                    
                    <Button Content="✕ Clear Backup Path" Padding="12,6" Margin="0,10,0,0"
                            Command="{Binding ClearBackupFolderCommand}"
                            Background="Transparent" Foreground="Red" BorderBrush="Red" BorderThickness="1"
                            Cursor="Hand" HorizontalAlignment="Left" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>
            </GroupBox>

            <!-- Security -->
            <GroupBox Header="🔐 Security" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Master Password (AES-256):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <CheckBox Content="Use Master Password" IsChecked="{Binding UseMasterPassword}" Margin="0,0,0,10" Foreground="{StaticResource FgBrush}"/>
                    <StackPanel Orientation="Horizontal">
                        <PasswordBox x:Name="MasterPwdBox" Width="200" Height="26" Margin="0,0,10,0" Padding="4"/>
                        <Button Content="Set / Change" Padding="12,4" Command="{Binding ChangeMasterPasswordCommand}" CommandParameter="{Binding ElementName=MasterPwdBox}" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                    <TextBlock Text="Requires restart to apply. If forgotten, your passwords will be lost!" Foreground="Red" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Appearance -->
            <GroupBox Header="🎨 Appearance" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Theme:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Themes}"
                              SelectedItem="{Binding SelectedTheme}"
                              Width="150" HorizontalAlignment="Left" Padding="8,4"/>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                              Content="Minimize to system tray"
                              IsChecked="{Binding MinimizeToTray}" Margin="0,10,0,0"/>
                </Grid>
            </GroupBox>

            <!-- Defaults -->
            <GroupBox Header="⚙️ Defaults" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Default RDP port:" 
                               VerticalAlignment="Center" Margin="0,0,10,10"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DefaultRdpPort}"
                             Width="80" HorizontalAlignment="Left" Padding="6,3"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Default SSH port:" 
                               VerticalAlignment="Center" Margin="0,0,10,10"/>
                    <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding DefaultSshPort}"
                             Width="80" HorizontalAlignment="Left" Padding="6,3"/>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" 
                              Content="Auto-reconnect on disconnect"
                              IsChecked="{Binding AutoReconnect}" Margin="0,5,0,0"/>
                </Grid>
            </GroupBox>

            <!-- Domain Credentials Mapping -->
            <GroupBox Header="🔑 Domain Credentials (Автопідстановка паролів)" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Налаштуйте логіни та паролі для кожного домену (наприклад, IT або smarttender). Вони автоматично підставлятимуться при підключенні!" 
                               FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Domain / Домен" FontWeight="SemiBold" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="Username / Логін" FontWeight="SemiBold" FontSize="11"/>
                        <TextBlock Grid.Column="2" Text="Password / Пароль" FontWeight="SemiBold" FontSize="11"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding DomainCredentials}" Margin="0,0,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" Padding="6,4"/>
                                    <TextBox Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" Padding="6,4"/>
                                    <PasswordBox Grid.Column="2" h:PasswordBoxHelper.BindPassword="True" h:PasswordBoxHelper.BoundPassword="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" Padding="6,4"/>
                                    <Button Grid.Column="3" Content="✕" FontWeight="Bold" Foreground="Red" Padding="8,4"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.DeleteDomainCredentialCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="➕ Add Domain Credential" Padding="12,6"
                            Command="{Binding AddDomainCredentialCommand}"
                            Background="Transparent" Foreground="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                            Cursor="Hand" HorizontalAlignment="Left" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>
            </GroupBox>

            <!-- Snippets -->
            <GroupBox Header="📝 Snippets / Macros (Скрипти та команди)" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Додайте часто використовувані скрипти, які можна буде швидко виконати в SSH терміналі в один клік!" 
                               FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name / Назва" FontWeight="SemiBold" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="Command / Команда" FontWeight="SemiBold" FontSize="11"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Snippets}" Margin="0,0,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" Padding="6,4"/>
                                    <TextBox Grid.Column="1" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" Padding="6,4"/>
                                    <Button Grid.Column="2" Content="✕" FontWeight="Bold" Foreground="Red" Padding="8,4"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.DeleteSnippetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="➕ Add Snippet" Padding="12,6"
                            Command="{Binding AddSnippetCommand}"
                            Background="Transparent" Foreground="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                            Cursor="Hand" HorizontalAlignment="Left" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>
            </GroupBox>

            <Button Content="💾 Save Settings" Padding="14,10"
                    Command="{Binding SaveSettingsCommand}"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" HorizontalAlignment="Left"
                    FontSize="14" FontWeight="SemiBold"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
