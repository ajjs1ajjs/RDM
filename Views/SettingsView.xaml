<UserControl x:Class="RemoteManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:RemoteManager.Helpers">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel MaxWidth="700">
            <TextBlock Text="{x:Static h:L.Tab_Settings}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Database Location -->
            <GroupBox Header="{x:Static h:L.Settings_Database}" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="{x:Static h:L.Settings_DatabasePath}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding CurrentDbPath, Mode=OneWay}"
                                 IsReadOnly="True" Padding="8,6"/>
                        <Button Grid.Column="1" Content="{x:Static h:L.Settings_Browse}" Padding="12,6" Margin="8,0,0,0"
                                Command="{Binding ChangeDatabasePathCommand}"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                    <TextBlock Text="{x:Static h:L.Settings_DatabaseHint}" 
                               FontSize="11" Opacity="0.6" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Backup & Sync -->
            <GroupBox Header="{x:Static h:L.Settings_BackupSync}" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="{x:Static h:L.Settings_BackupSyncDesc}" 
                               FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="{x:Static h:L.Settings_Import}" Padding="14,6" Margin="0,0,10,0"
                                Command="{Binding ImportConnectionsCommand}"
                                Background="Transparent" Foreground="{StaticResource AccentBrush}" 
                                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Cursor="Hand"
                                FontSize="11" FontWeight="SemiBold"/>
                        <Button Content="{x:Static h:L.Settings_Export}" Padding="14,6"
                                Command="{Binding ExportConnectionsCommand}"
                                Background="Transparent" Foreground="{StaticResource AccentBrush}" 
                                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Cursor="Hand"
                                FontSize="11" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Border BorderBrush="{StaticResource CtrlBorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,15"/>

                    <TextBlock Text="{x:Static h:L.Settings_SecureBackup}" 
                               FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                    <TextBlock Text="{x:Static h:L.Settings_SecureBackupDesc}" 
                               FontSize="10" Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{x:Static h:L.Settings_ImportSecure}" Padding="14,8" Margin="0,0,10,0"
                                Command="{Binding ImportEncryptedBackupCommand}"
                                Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                FontSize="11" FontWeight="Bold"/>
                        <Button Content="{x:Static h:L.Settings_ExportSecure}" Padding="14,8"
                                Command="{Binding ExportEncryptedBackupCommand}"
                                Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Auto Backup Folder -->
            <GroupBox Header="{x:Static h:L.Settings_AutoBackup}" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="{x:Static h:L.Settings_AutoBackupDesc}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding BackupFolderPath, Mode=OneWay}"
                                 IsReadOnly="True" Padding="8,6"/>
                        <Button Grid.Column="1" Content="{x:Static h:L.Settings_Browse}" Padding="12,6" Margin="8,0,0,0"
                                Command="{Binding ChangeBackupFolderCommand}"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                    <TextBlock Text="{x:Static h:L.Settings_BackupNote}" 
                               FontSize="11" Opacity="0.6" Margin="0,5,0,0" TextWrapping="Wrap"/>
                    
                    <Button Content="{x:Static h:L.Settings_ClearBackupPath}" Padding="12,6" Margin="0,10,0,0"
                            Command="{Binding ClearBackupFolderCommand}"
                            Background="Transparent" Foreground="Red" BorderBrush="Red" BorderThickness="1"
                            Cursor="Hand" HorizontalAlignment="Left" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>
            </GroupBox>

            <!-- Security -->
            <GroupBox Header="{x:Static h:L.Settings_Security}" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="{x:Static h:L.Settings_MasterPassword}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <CheckBox Content="{x:Static h:L.Settings_UseMasterPassword}" IsChecked="{Binding UseMasterPassword}" Margin="0,0,0,10" Foreground="{StaticResource FgBrush}"/>
                    <StackPanel Orientation="Horizontal">
                        <PasswordBox x:Name="MasterPwdBox" Width="200" Height="26" Margin="0,0,10,0" Padding="4"/>
                        <Button Content="{x:Static h:L.Settings_SetChange}" Padding="12,4" Command="{Binding ChangeMasterPasswordCommand}" CommandParameter="{Binding ElementName=MasterPwdBox}" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static h:L.Settings_MasterPasswordWarning}" Foreground="Red" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Appearance -->
            <GroupBox Header="{x:Static h:L.Settings_Appearance}" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static h:L.Settings_Theme}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Themes}"
                              SelectedItem="{Binding SelectedTheme}"
                              Width="150" HorizontalAlignment="Left" Padding="8,4"/>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                              Content="{x:Static h:L.Settings_MinimizeToTray}"
                              IsChecked="{Binding MinimizeToTray}" Margin="0,10,0,0"/>
                </Grid>
            </GroupBox>

            <!-- Defaults -->
            <GroupBox Header="{x:Static h:L.Settings_Defaults}" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static h:L.Settings_DefaultRDPPort}" 
                               VerticalAlignment="Center" Margin="0,0,10,10"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DefaultRdpPort}"
                             Width="80" HorizontalAlignment="Left" Padding="6,3"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{x:Static h:L.Settings_DefaultSSHPort}" 
                               VerticalAlignment="Center" Margin="0,0,10,10"/>
                    <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding DefaultSshPort}"
                             Width="80" HorizontalAlignment="Left" Padding="6,3"/>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" 
                              Content="{x:Static h:L.Settings_AutoReconnect}"
                              IsChecked="{Binding AutoReconnect}" Margin="0,5,0,0"/>
                </Grid>
            </GroupBox>

            <!-- Domain Credentials Mapping -->
            <GroupBox Header="{x:Static h:L.Settings_DomainCredentials}" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="{x:Static h:L.Settings_DomainCredentialsDesc}" 
                               FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="100"/>
                            <ColumnDefinition Width="*" MinWidth="80"/>
                            <ColumnDefinition Width="*" MinWidth="100"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Static h:L.Settings_Domain}" FontWeight="SemiBold" FontSize="11" Margin="0,0,4,0"/>
                        <TextBlock Grid.Column="1" Text="{x:Static h:L.Settings_Username}" FontWeight="SemiBold" FontSize="11" Margin="0,0,4,0"/>
                        <TextBlock Grid.Column="2" Text="{x:Static h:L.Settings_Password}" FontWeight="SemiBold" FontSize="11" Margin="0,0,4,0"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding DomainCredentials}" Margin="0,0,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="100"/>
                                        <ColumnDefinition Width="*" MinWidth="80"/>
                                        <ColumnDefinition Width="*" MinWidth="100"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" Padding="6,4"/>
                                    <TextBox Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" Padding="6,4"/>
                                    <PasswordBox Grid.Column="2" h:PasswordBoxHelper.BindPassword="True" h:PasswordBoxHelper.BoundPassword="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" Padding="6,4"/>
                                    <Button Grid.Column="3" Content="✕" FontWeight="Bold" Foreground="Red" Padding="0"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.DeleteDomainCredentialCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="{x:Static h:L.Settings_AddDomainCredential}" Padding="12,6"
                            Command="{Binding AddDomainCredentialCommand}"
                            Background="Transparent" Foreground="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                            Cursor="Hand" HorizontalAlignment="Left" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>
            </GroupBox>

            <!-- Snippets -->
            <GroupBox Header="{x:Static h:L.Settings_Snippets}" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="{x:Static h:L.Settings_SnippetsDesc}" 
                               FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" MinWidth="80"/>
                            <ColumnDefinition Width="5*" MinWidth="120"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Static h:L.Settings_Name}" FontWeight="SemiBold" FontSize="11" Margin="0,0,4,0"/>
                        <TextBlock Grid.Column="1" Text="{x:Static h:L.Settings_Command}" FontWeight="SemiBold" FontSize="11" Margin="0,0,4,0"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Snippets}" Margin="0,0,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" MinWidth="80"/>
                                        <ColumnDefinition Width="5*" MinWidth="120"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" Padding="6,4"/>
                                    <TextBox Grid.Column="1" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" Padding="6,4"/>
                                    <Button Grid.Column="2" Content="✕" FontWeight="Bold" Foreground="Red" Padding="0"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.DeleteSnippetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="{x:Static h:L.Settings_AddSnippet}" Padding="12,6"
                            Command="{Binding AddSnippetCommand}"
                            Background="Transparent" Foreground="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                            Cursor="Hand" HorizontalAlignment="Left" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>
            </GroupBox>

            <Button Content="{x:Static h:L.Settings_SaveSettings}" Padding="14,10"
                    Command="{Binding SaveSettingsCommand}"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" HorizontalAlignment="Left"
                    FontSize="14" FontWeight="SemiBold"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
