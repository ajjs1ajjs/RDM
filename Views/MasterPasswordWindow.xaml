<Window x:Class="RemoteManager.Views.MasterPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter Master Password" Height="200" Width="350"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1F1F1F" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Enter Master Password:" FontSize="14" Margin="0,0,0,10"/>
        
        <PasswordBox x:Name="PasswordBox" Grid.Row="1" Height="30" Margin="0,0,0,20" 
                     Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="4"/>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Height="30" Margin="0,0,10,0" Click="Cancel_Click" Background="#3F3F46" Foreground="White" BorderThickness="0"/>
            <Button Content="Unlock" Width="80" Height="30" Click="Unlock_Click" IsDefault="True" Background="#007ACC" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
