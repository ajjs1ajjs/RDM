<UserControl x:Class="RemoteManager.Views.RdpSessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RemoteManager.Controls"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
             Background="Black">
    <Grid Background="Black" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- RDP Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource CtrlBorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="🖥 Full Screen" Margin="2,0" FontSize="11"
                        Command="{Binding ToggleFullScreenCommand}"
                        Padding="8,4" Background="{StaticResource AccentBrush}" Foreground="White"/>
                <Button Content="Ctrl+Alt+Del" Margin="2,0" FontSize="11"
                        Command="{Binding SendCtrlAltDelCommand}"
                        Padding="8,4" Background="{StaticResource AccentBrush}" Foreground="White"/>

                <Separator Width="1" Background="{StaticResource CtrlBorderBrush}" Margin="8,4"/>

                <Button Content="🔄 Reconnect" Margin="2,0" FontSize="11"
                        Command="{Binding ConnectRdpCommand}"
                        Padding="8,4" Background="{StaticResource GreenBrush}" Foreground="White"/>
                <Button Content="⛔ Disconnect" Margin="2,0" FontSize="11"
                        Command="{Binding DisconnectCommand}"
                        Padding="8,4" Background="{StaticResource RedBrush}" Foreground="White"/>

                <Separator Width="1" Background="{StaticResource CtrlBorderBrush}" Margin="8,4"/>
                <TextBlock Text="{Binding SessionInfo}" VerticalAlignment="Center" Margin="10,0,4,0"
                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}"/>
                <TextBlock Text="·" VerticalAlignment="Center" Margin="4,0" FontSize="11" Foreground="{StaticResource FgBrush}"/>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="4,0"
                           FontSize="11" Foreground="{StaticResource FgBrush}" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <controls:RdpHost Grid.Row="1" x:Name="RdpControl"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </Grid>
</UserControl>
